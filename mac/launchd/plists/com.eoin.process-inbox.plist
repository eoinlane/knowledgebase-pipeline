<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.eoin.process-inbox</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/python3</string>
        <string>/Users/eoin/knowledgebase-pipeline/process_inbox.py</string>
    </array>

    <key>WatchPaths</key>
    <array>
        <string>/Users/eoin/inbox</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/eoin/.local/bin/process-inbox.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/eoin/.local/bin/process-inbox.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/eoin</string>
    </dict>
</dict>
</plist>
