<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.eoin.refresh-memory-symlinks</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/eoin/knowledgebase-pipeline/mac/setup-memory-symlinks.sh</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <!-- Pipeline memory dir: fires when a memory file is added, removed,
             or renamed. Catches new cross-cutting dossiers. -->
        <string>/Users/eoin/.claude/projects/-Users-eoin-knowledgebase-pipeline/memory</string>
        <!-- Documents root: fires when a new project folder appears or an
             existing one is renamed. Auto-discovery picks it up. -->
        <string>/Users/eoin/Documents</string>
    </array>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/Users/eoin/.local/bin/refresh-memory-symlinks.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/eoin/.local/bin/refresh-memory-symlinks.log</string>
</dict>
</plist>
